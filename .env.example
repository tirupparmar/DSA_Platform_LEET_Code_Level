# ==========================================
# AlgoSim Environment Variables
# ==========================================
# Copy this to .env.local and fill in values

# ----- Database (Free: Supabase / Neon) -----
DATABASE_URL="postgresql://postgres:password@host:5432/algosim?sslmode=require"

# ----- NextAuth -----
NEXTAUTH_SECRET="your-random-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ----- OAuth (Optional but recommended) -----
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----- Code Execution (Free: Judge0 CE self-hosted or public) -----
# Option A: Use free public Judge0 CE (rate limited)
JUDGE0_API_URL="https://judge0-ce.p.rapidapi.com"
JUDGE0_API_KEY=""
# Option B: Self-hosted on Railway/Render (see docs)
# JUDGE0_API_URL="https://your-judge0.railway.app"

# ----- Redis (Free: Upstash) -----
REDIS_URL="redis://localhost:6379"
# For Upstash:
# REDIS_URL="rediss://default:token@host.upstash.io:6379"

# ----- App Config -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NODE_ENV="development"

# ----- AI Hints (Optional: Free Gemini API) -----
GEMINI_API_KEY=""
